# Source: https://github.com/kserve/kserve/blob/v0.17.0/config/llmisvcconfig/config-llm-decode-worker-data-parallel.yaml
apiVersion: serving.kserve.io/v1alpha2
kind: LLMInferenceServiceConfig
metadata:
  name: kserve-config-llm-decode-worker-data-parallel
  namespace: {% endraw %}{{ namespace }}{% raw %}
spec:
  template:
    containers:
    - command:
      - /bin/bash
      - -c
      - |2-

        if [ "$KSERVE_INFER_ROCE" = "true" ]; then
          echo "Trying to infer RoCE configs ... "
          grep -H . /sys/class/infiniband/*/ports/*/gids/* 2>/dev/null
          grep -H . /sys/class/infiniband/*/ports/*/gid_attrs/types/* 2>/dev/null

          KSERVE_INFER_IB_GID_INDEX_GREP=${KSERVE_INFER_IB_GID_INDEX_GREP:-"RoCE v2"}

          echo "[Infer RoCE] Discovering active HCAs ..."
          active_hcas=()
          for hca_dir in /sys/class/infiniband/mlx5_*; do
              if [ -d "$hca_dir" ]; then
                  hca_name=$(basename "$hca_dir")
                  port_state_file="$hca_dir/ports/1/state"
                  type_file="$hca_dir/ports/1/gid_attrs/types/*"

                  if [ -f "$port_state_file" ] && grep -q "ACTIVE" "$port_state_file" && grep -q "${KSERVE_INFER_IB_GID_INDEX_GREP}" ${type_file} 2>/dev/null; then
                      active_hcas+=("$hca_name")
                  fi
              fi
          done

          ucx_hcas=()
          for hca in "${active_hcas[@]}"; do
            ucx_hcas+=("${hca}:1")
          done

          if [ ${#active_hcas[@]} -gt 0 ]; then
              hcas=$(IFS=,; echo "${active_hcas[*]}")
              export NCCL_IB_HCA=${NCCL_IB_HCA:-${hcas}}
              export NVSHMEM_HCA_LIST=${NVSHMEM_HCA_LIST:-${hcas}}
              export UCX_NET_DEVICES=${UCX_NET_DEVICES:-${ucx_hcas}}
          fi

          if [ ${#active_hcas[@]} -gt 0 ]; then
              declare -A gid_index_count
              declare -A hca_gid_index

              for hca_name in "${active_hcas[@]}"; do
                  for tpath in /sys/class/infiniband/${hca_name}/ports/1/gid_attrs/types/*; do
                      if grep -q "${KSERVE_INFER_IB_GID_INDEX_GREP}" "$tpath" 2>/dev/null; then
                          idx=$(basename "$tpath")
                          gid_file="/sys/class/infiniband/${hca_name}/ports/1/gids/${idx}"
                          if [ -f "$gid_file" ] && grep -q "ffff:" "$gid_file"; then
                              hca_gid_index["${hca_name}"]="${idx}"
                              gid_index_count["${idx}"]=$((${gid_index_count["${idx}"]} + 1))
                              break
                          fi
                      fi
                  done
              done

              best_gid_index=""
              max_count=0
              for idx in "${!gid_index_count[@]}"; do
                  count=${gid_index_count["${idx}"]}
                  if [ $count -gt $max_count ]; then
                      max_count=$count
                      best_gid_index="$idx"
                  fi
              done

              if [ ${#gid_index_count[@]} -gt 1 ]; then
                  if [ -n "${gid_index_count['3']}" ] && [ "${gid_index_count['3']}" -eq "$max_count" ]; then
                      best_gid_index="3"
                  fi
              fi

              if [ -n "${NCCL_IB_GID_INDEX}" ]; then
                  export NVSHMEM_IB_GID_INDEX=${NVSHMEM_IB_GID_INDEX:-$NCCL_IB_GID_INDEX}
                  export UCX_IB_GID_INDEX=${UCX_IB_GID_INDEX:-$NCCL_IB_GID_INDEX}
              elif [ -n "$best_gid_index" ]; then
                  export NCCL_IB_GID_INDEX=${NCCL_IB_GID_INDEX:-$best_gid_index}
                  export NVSHMEM_IB_GID_INDEX=${NVSHMEM_IB_GID_INDEX:-$best_gid_index}
                  export UCX_IB_GID_INDEX=${UCX_IB_GID_INDEX:-$best_gid_index}
              fi
          fi
        fi

        START_RANK=0
        eval "vllm serve \
          /mnt/models \
          --served-model-name '{{ .Spec.Model.Name }}' \
          --port 8001 \
          --api-server-count ${VLLM_API_SERVER_COUNT:-8} \
          {{- if .Spec.Parallelism.Expert -}}--enable-expert-parallel{{- end }} \
          {{- if .Spec.Parallelism.Tensor -}}--tensor-parallel-size {{ .Spec.Parallelism.Tensor }}{{- end }} \
          --data-parallel-size {{ or .Spec.Parallelism.Data 1 }} \
          --data-parallel-size-local {{ or .Spec.Parallelism.DataLocal 1 }} \
          --data-parallel-address $(LWS_LEADER_ADDRESS) \
          --data-parallel-rpc-port {{ if .Spec.Parallelism.DataRPCPort }}{{ .Spec.Parallelism.DataRPCPort }}{{ else }}5555{{- end }} \
          --data-parallel-start-rank $START_RANK \
          ${VLLM_ADDITIONAL_ARGS} \
          $@ \
          --trust-remote-code"
      - --
      env:
      - name: HOME
        value: /home
      - name: VLLM_LOGGING_LEVEL
        value: INFO
      - name: HF_HUB_CACHE
        value: /models
      image: {% endraw %}{{ workload_image }}{% raw %}
      imagePullPolicy: IfNotPresent
      livenessProbe:
        failureThreshold: 3
        httpGet:
          path: /health
          port: 8001
          scheme: HTTP
        periodSeconds: 10
        timeoutSeconds: 10
      name: main
      ports:
      - containerPort: 8001
        protocol: TCP
      readinessProbe:
        failureThreshold: 60
        httpGet:
          path: /health
          port: 8001
          scheme: HTTP
        periodSeconds: 30
        timeoutSeconds: 5
      securityContext:
        allowPrivilegeEscalation: false
        capabilities:
          add:
          - IPC_LOCK
          - SYS_RAWIO
          - NET_RAW
          drop:
          - ALL
        readOnlyRootFilesystem: false
        runAsNonRoot: false
        seccompProfile:
          type: RuntimeDefault
      startupProbe:
        failureThreshold: 60
        httpGet:
          path: /health
          port: 8001
          scheme: HTTP
        periodSeconds: 10
      terminationMessagePath: /dev/termination-log
      terminationMessagePolicy: FallbackToLogsOnError
      volumeMounts:
      - mountPath: /home
        name: home
      - mountPath: /dev/shm
        name: dshm
      - mountPath: /models
        name: model-cache
      - mountPath: /var/run/kserve/tls
        name: tls-certs
        readOnly: true
    initContainers:
    - args:
      - --port=8000
      - --vllm-port=8001
      - --connector=nixlv2
      - --secure-proxy=false
      env:
      - name: INFERENCE_POOL_NAMESPACE
        valueFrom:
          fieldRef:
            fieldPath: metadata.namespace
      image: {% endraw %}{{ llm_routing_sidecar }}{% raw %}
      imagePullPolicy: IfNotPresent
      livenessProbe:
        failureThreshold: 3
        httpGet:
          path: /health
          port: 8000
          scheme: HTTP
        initialDelaySeconds: 10
        periodSeconds: 10
        timeoutSeconds: 10
      name: llm-d-routing-sidecar
      ports:
      - containerPort: 8000
        protocol: TCP
      readinessProbe:
        failureThreshold: 10
        httpGet:
          path: /health
          port: 8000
          scheme: HTTP
        initialDelaySeconds: 10
        periodSeconds: 10
        timeoutSeconds: 5
      restartPolicy: Always
      securityContext:
        allowPrivilegeEscalation: false
        capabilities:
          drop:
          - ALL
        readOnlyRootFilesystem: true
        runAsNonRoot: false
        seccompProfile:
          type: RuntimeDefault
      terminationMessagePath: /dev/termination-log
      terminationMessagePolicy: FallbackToLogsOnError
      volumeMounts:
      - mountPath: /var/run/kserve/tls
        name: tls-certs
        readOnly: true
    terminationGracePeriodSeconds: 30
    volumes:
    - emptyDir: {}
      name: home
    - emptyDir:
        medium: Memory
        sizeLimit: 1Gi
      name: dshm
    - emptyDir: {}
      name: model-cache
    - name: tls-certs
      secret:
        secretName: '{{ ChildName .ObjectMeta.Name `-kserve-self-signed-certs` }}'
  worker:
    containers:
    - command:
      - /bin/bash
      - -c
      - |2-

        if [ "$KSERVE_INFER_ROCE" = "true" ]; then
          echo "Trying to infer RoCE configs ... "
          grep -H . /sys/class/infiniband/*/ports/*/gids/* 2>/dev/null
          grep -H . /sys/class/infiniband/*/ports/*/gid_attrs/types/* 2>/dev/null

          KSERVE_INFER_IB_GID_INDEX_GREP=${KSERVE_INFER_IB_GID_INDEX_GREP:-"RoCE v2"}

          echo "[Infer RoCE] Discovering active HCAs ..."
          active_hcas=()
          for hca_dir in /sys/class/infiniband/mlx5_*; do
              if [ -d "$hca_dir" ]; then
                  hca_name=$(basename "$hca_dir")
                  port_state_file="$hca_dir/ports/1/state"
                  type_file="$hca_dir/ports/1/gid_attrs/types/*"

                  if [ -f "$port_state_file" ] && grep -q "ACTIVE" "$port_state_file" && grep -q "${KSERVE_INFER_IB_GID_INDEX_GREP}" ${type_file} 2>/dev/null; then
                      active_hcas+=("$hca_name")
                  fi
              fi
          done

          ucx_hcas=()
          for hca in "${active_hcas[@]}"; do
            ucx_hcas+=("${hca}:1")
          done

          if [ ${#active_hcas[@]} -gt 0 ]; then
              hcas=$(IFS=,; echo "${active_hcas[*]}")
              export NCCL_IB_HCA=${NCCL_IB_HCA:-${hcas}}
              export NVSHMEM_HCA_LIST=${NVSHMEM_HCA_LIST:-${hcas}}
              export UCX_NET_DEVICES=${UCX_NET_DEVICES:-${ucx_hcas}}
          fi

          if [ ${#active_hcas[@]} -gt 0 ]; then
              declare -A gid_index_count
              declare -A hca_gid_index

              for hca_name in "${active_hcas[@]}"; do
                  for tpath in /sys/class/infiniband/${hca_name}/ports/1/gid_attrs/types/*; do
                      if grep -q "${KSERVE_INFER_IB_GID_INDEX_GREP}" "$tpath" 2>/dev/null; then
                          idx=$(basename "$tpath")
                          gid_file="/sys/class/infiniband/${hca_name}/ports/1/gids/${idx}"
                          if [ -f "$gid_file" ] && grep -q "ffff:" "$gid_file"; then
                              hca_gid_index["${hca_name}"]="${idx}"
                              gid_index_count["${idx}"]=$((${gid_index_count["${idx}"]} + 1))
                              break
                          fi
                      fi
                  done
              done

              best_gid_index=""
              max_count=0
              for idx in "${!gid_index_count[@]}"; do
                  count=${gid_index_count["${idx}"]}
                  if [ $count -gt $max_count ]; then
                      max_count=$count
                      best_gid_index="$idx"
                  fi
              done

              if [ ${#gid_index_count[@]} -gt 1 ]; then
                  if [ -n "${gid_index_count['3']}" ] && [ "${gid_index_count['3']}" -eq "$max_count" ]; then
                      best_gid_index="3"
                  fi
              fi

              if [ -n "${NCCL_IB_GID_INDEX}" ]; then
                  export NVSHMEM_IB_GID_INDEX=${NVSHMEM_IB_GID_INDEX:-$NCCL_IB_GID_INDEX}
                  export UCX_IB_GID_INDEX=${UCX_IB_GID_INDEX:-$NCCL_IB_GID_INDEX}
              elif [ -n "$best_gid_index" ]; then
                  export NCCL_IB_GID_INDEX=${NCCL_IB_GID_INDEX:-$best_gid_index}
                  export NVSHMEM_IB_GID_INDEX=${NVSHMEM_IB_GID_INDEX:-$best_gid_index}
                  export UCX_IB_GID_INDEX=${UCX_IB_GID_INDEX:-$best_gid_index}
              fi
          fi
        fi

        START_RANK=$(( ${LWS_WORKER_INDEX:-0} * {{ or .Spec.Parallelism.DataLocal 1 }} ))
        eval "vllm serve \
          /mnt/models \
          --served-model-name '{{ .Spec.Model.Name }}' \
          --port 8001 \
          {{- if .Spec.Parallelism.Expert }}--enable-expert-parallel{{- end }} \
          {{- if .Spec.Parallelism.Tensor }}--tensor-parallel-size {{ .Spec.Parallelism.Tensor }}{{- end }} \
          --data-parallel-size {{ or .Spec.Parallelism.Data 1 }} \
          --data-parallel-size-local {{ or .Spec.Parallelism.DataLocal 1 }} \
          --data-parallel-address $(LWS_LEADER_ADDRESS) \
          --data-parallel-rpc-port {{ if .Spec.Parallelism.DataRPCPort }}{{ .Spec.Parallelism.DataRPCPort }}{{ else }}5555{{- end }} \
          --data-parallel-start-rank $START_RANK \
          ${VLLM_ADDITIONAL_ARGS} \
          $@ \
          --trust-remote-code \
          --headless"
      - --
      env:
      - name: HOME
        value: /home
      - name: VLLM_LOGGING_LEVEL
        value: INFO
      - name: HF_HUB_CACHE
        value: /models
      - name: VLLM_RANDOMIZE_DP_DUMMY_INPUTS
        value: "1"
      image: {% endraw %}{{ workload_image }}{% raw %}
      imagePullPolicy: IfNotPresent
      name: main
      ports:
      - containerPort: 8001
        protocol: TCP
      securityContext:
        allowPrivilegeEscalation: false
        capabilities:
          add:
          - IPC_LOCK
          - SYS_RAWIO
          - NET_RAW
          drop:
          - ALL
        readOnlyRootFilesystem: false
        runAsNonRoot: false
        seccompProfile:
          type: RuntimeDefault
      terminationMessagePath: /dev/termination-log
      terminationMessagePolicy: FallbackToLogsOnError
      volumeMounts:
      - mountPath: /home
        name: home
      - mountPath: /dev/shm
        name: dshm
      - mountPath: /models
        name: model-cache
      - mountPath: /var/run/kserve/tls
        name: tls-certs
        readOnly: true
    terminationGracePeriodSeconds: 30
    volumes:
    - emptyDir: {}
      name: home
    - emptyDir:
        medium: Memory
        sizeLimit: 1Gi
      name: dshm
    - emptyDir: {}
      name: model-cache
    - name: tls-certs
      secret:
        secretName: '{{ ChildName .ObjectMeta.Name `-kserve-self-signed-certs` }}'
